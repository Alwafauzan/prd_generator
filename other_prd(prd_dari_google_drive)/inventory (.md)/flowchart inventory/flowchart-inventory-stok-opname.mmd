    B11{Masih ada barang sisa?}
    B12[Status SO Selesai dan lepas freeze]
  end
  subgraph Petugas_Penghitung
    C1[Input hasil hitung fisik per barang]
    C2[Input per batch untuk farmasi]
  end
  subgraph Kepala_Unit
    D1[Review hasil opname]
    D2{Disetujui?}
    D3[Tentukan lingkup approval]
  end
  subgraph Akuntansi
